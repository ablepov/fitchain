# Fitchain local environment
# Copy to .env.local for local development

NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url

# Use either publishable key or anon key.
# The app currently supports both, preferring NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY when present.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Live e2e credentials for a dedicated Supabase test user.
E2E_TEST_EMAIL=your_e2e_test_email
E2E_TEST_PASSWORD=your_e2e_test_password
